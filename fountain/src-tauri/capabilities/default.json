{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for Fountain",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:tray:default",
    "shell:allow-open",
    "notification:default",
    "store:default",
    "dialog:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "log:default",
    "allow-open-settings-window",
    "allow-get-settings",
    "allow-save-settings",
    "allow-test-server-connection",
    "allow-get-credential",
    "allow-set-credential",
    "allow-delete-credential",
    "allow-validate-bilibili-cookie",
    "allow-start-bilibili-qr-login",
    "allow-poll-bilibili-qr-status",
    "allow-validate-wechat-read-cookie",
    "allow-open-wechat-webview",
    "allow-capture-wechat-cookies",
    "allow-close-wechat-webview",
    "allow-open-douban-webview",
    "allow-capture-douban-cookies",
    "allow-validate-douban-cookie",
    "allow-open-zhihu-webview",
    "allow-capture-zhihu-cookies",
    "allow-validate-zhihu-cookie",
    "allow-validate-github-token",
    "allow-open-twitter-webview",
    "allow-capture-twitter-ct0",
    "allow-save-twitter-cookies",
    "allow-validate-twitter-cookie",
    "allow-sync-now",
    "allow-sync-platform",
    "allow-get-sync-status"
  ]
}
